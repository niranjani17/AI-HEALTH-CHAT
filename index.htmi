<!DOCTYPE html>
<html>
<head>
    <title>AI Public Health Chatbot</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

<div class="chat-container">
    <h2>Health Awareness Chatbot</h2>
    <div id="chatbox"></div>
    
    <input type="text" id="userInput" placeholder="Ask about diseases...">
    <button onclick="sendMessage()">Send</button>
</div>

<script src="script.js"></script>

</body>
</html>